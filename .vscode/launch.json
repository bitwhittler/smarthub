{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Smarthub",
      "type": "debugpy",
      "request": "launch",
      "module": "smarthub",
      "args": [
        "--provider", "core",
        "--username", "your_user",
        "--password", "your_pass",
        "-vv"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Python: Debug Current Test File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
